# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LLM providers — at least one recommended; system works in fallback mode without any key
# Anthropic (priority 1 — claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (priority 2 — gpt-4o-mini)
OPENAI_API_KEY=sk-...

# File Storage
UPLOAD_DIR=./local_uploads
MAX_FILE_SIZE_MB=50
STORAGE_BACKEND=local  # "local" or "s3"

# S3 / Object Storage (used when STORAGE_BACKEND=s3)
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=  # custom endpoint for MinIO / DigitalOcean Spaces

# CORS
CORS_ORIGINS=http://localhost:3000

# Chat
CHAT_MAX_QUESTION_CHARS=4000

# Email (leave EMAIL_HOST empty to use console backend in development)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@example.com
FRONTEND_URL=http://localhost:8000
PASSWORD_RESET_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
DEBUG=false

# Vector DB
VECTOR_DB_PATH=./vector_db
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB (leave CHROMA_HOST empty for embedded/persistent mode)
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_TOKEN=
# CHROMA_HOST=chromadb  # Uncomment for client/server mode with docker-compose

# Security
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Rate Limits
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_DEFAULT=60/minute

# Redis / Celery (optional — falls back to FastAPI BackgroundTasks)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Stripe Billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# OpenTelemetry Tracing (leave empty to disable)
OTEL_EXPORTER_ENDPOINT=
# OTEL_EXPORTER_ENDPOINT=http://jaeger:4317  # Uncomment for Jaeger
OTEL_SERVICE_NAME=rag-api
